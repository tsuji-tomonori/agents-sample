DATABASE_PROVIDER=postgres
DATABASE_URL=postgres://chat:chat@localhost:5432/chat
PORT=8787

# local | cloud switch
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Cloud Bedrock settings
AWS_REGION=ap-northeast-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# For Aurora DSQL or another managed Postgres-compatible endpoint.
# Set DATABASE_PROVIDER=dsql and provide the DSQL hostname.
# AWS credentials must be available through env vars, AWS profile, or workload role.
DATABASE_SSL=false
DSQL_HOST=your-cluster-id.dsql.ap-northeast-1.on.aws
DSQL_USER=admin
DSQL_DATABASE=postgres
