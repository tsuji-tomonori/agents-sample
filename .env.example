DATABASE_PROVIDER=postgres
DATABASE_URL=postgres://chat:chat@localhost:5432/chat
PORT=8787

# local | cloud | microvm switch
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Cloud Bedrock settings
AWS_REGION=ap-northeast-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0

# MicroVM agent settings.
# Set LLM_PROVIDER=microvm and choose MICROVM_AGENT=codex or MICROVM_AGENT=claude.
ARTIFACT_BUCKET=your-agent-artifact-bucket
OUTPUT_PREFIX=chat-runs/
MICROVM_AGENT=codex
MICROVM_IMAGE_IDENTIFIER=arn:aws:lambda:ap-northeast-1:123456789012:microvm-image:your-image
CODEX_MICROVM_IMAGE_IDENTIFIER=
CLAUDE_MICROVM_IMAGE_IDENTIFIER=
MICROVM_IMAGE_VERSION=1.0
MICROVM_EXECUTION_ROLE_ARN=
MICROVM_MAXIMUM_DURATION_SECONDS=900
MICROVM_RESULT_TIMEOUT_MS=840000
MICROVM_RESULT_DETAIL_TIMEOUT_MS=10000
MICROVM_TERMINATE=true
BEDROCK_REGION=ap-northeast-1
CODEX_MODEL=openai.gpt-oss-120b-1:0
CLAUDE_MODEL_ID=apac.anthropic.claude-3-5-sonnet-20240620-v1:0

# For Aurora DSQL or another managed Postgres-compatible endpoint.
# Set DATABASE_PROVIDER=dsql and provide the DSQL hostname.
# AWS credentials must be available through env vars, AWS profile, or workload role.
DATABASE_SSL=false
DSQL_HOST=your-cluster-id.dsql.ap-northeast-1.on.aws
DSQL_USER=admin
DSQL_DATABASE=postgres
